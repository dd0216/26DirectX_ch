#include <d3d11.h>        // DirectX 11의 핵심 기능 도구함
#include <d3dcompiler.h>   // 셰이더(그래픽 계산 프로그램)를 컴파일하는 도구
#include <stdio.h>        // 표준 입출력 (printf 등)
